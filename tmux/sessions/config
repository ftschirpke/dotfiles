#!/usr/bin/env bash

name=$(basename "$0")
dir=$XDG_CONFIG_HOME
echo "Starting tmux session $name"
window1="bash"
tmux new-session -d -s $name -n $window1 -c $dir

window2="nvim"
tmux new-window -d -t $name:2 -n $window2 -c $dir
tmux send-keys -t $selected_name:$window2 "nvim ." Enter

window3="git"
tmux new-window -d -t $name:3 -n $window3 -c $dir
tmux send-keys -t $selected_name:$window2 "git fetch --all -p" Enter
tmux send-keys -t $selected_name:$window2 "git status" Enter

tmux_switch_session $name
